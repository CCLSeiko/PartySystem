# DonationSystem Backend Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/donationsystem
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/donationsystem

# Application
APP_NAME=DonationSystem
DEBUG=true

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Encryption
ENCRYPTION_KEY=
